# Example environment variables for Tram.AI local development
# Copy this to `.env` and fill values as appropriate.

# Flask/FastAPI app settings
FLASK_ENV=development
SECRET_KEY=replace-me

# Database and cache (if the project uses Postgres+Redis)
DATABASE_URL=postgresql://user:pass@localhost:5432/tramai
REDIS_URL=redis://localhost:6379/0

# API key for the generative AI service used by `AIService`.
# If unset, the AI service will use a deterministic fallback stub.
AI_API_KEY=

# MapPLS / MapMyIndia API key. If unset, routing falls back to public OSRM demo server.
MAPPLS_API_KEY=

# Uvicorn server host and port (used if running `python -m app.main` directly)
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# DuckDuckGo search region and safesearch (optional)
DDG_REGION=wt-wt
DDG_SAFESERACH=Moderate
